<Page x:Class="F1Dashboard.Views.EventSchedule"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <ListView ItemsSource="{Binding Events}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Event Name" DisplayMemberBinding="{Binding Name}" Width="200"/>
                    <GridViewColumn Header="Country" DisplayMemberBinding="{Binding Country}" Width="150"/>
                    <GridViewColumn Header="Location" DisplayMemberBinding="{Binding Location}" Width="150"/>
                    <GridViewColumn Header="Date" DisplayMemberBinding="{Binding Date}" Width="120"/>
                    <GridViewColumn Header="Time" DisplayMemberBinding="{Binding StartTime}" Width="100"/>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</Page>
