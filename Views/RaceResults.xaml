<Page x:Class="F1_Dashboard.Views.RaceResults"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <ListView ItemsSource="{Binding RaceResults}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Driver" DisplayMemberBinding="{Binding DriverName}" Width="200"/>
                    <GridViewColumn Header="Team" DisplayMemberBinding="{Binding Team}" Width="200"/>
                    <GridViewColumn Header="Grid Position" DisplayMemberBinding="{Binding GridPosition}" Width="100"/>
                    <GridViewColumn Header="Finish Position" DisplayMemberBinding="{Binding FinishPosition}" Width="100"/>
                    <GridViewColumn Header="Points" DisplayMemberBinding="{Binding Points}" Width="100"/>
                    <GridViewColumn Header="Status" DisplayMemberBinding="{Binding Status}" Width="150"/>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</Page>


